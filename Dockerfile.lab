FROM python:3.12-slim-bookworm

WORKDIR /app

RUN pip install --no-cache-dir \
    jupyterlab \
    dhanhq>=2.2.0 \
    pandas \
    pandas-ta \
    numpy \
    matplotlib \
    plotly \
    requests \
    python-dotenv \
    tabulate

COPY data_querying.py instruments_search.py ./

RUN useradd -r -m -d /home/labuser labuser
RUN mkdir -p /app/notebooks && chown -R labuser:labuser /app

ENV PYTHONPATH=/app

USER labuser

EXPOSE 8888

CMD ["jupyter", "lab", \
     "--ip=0.0.0.0", \
     "--port=8888", \
     "--no-browser", \
     "--ServerApp.token=''", \
     "--ServerApp.password=''", \
     "--ServerApp.base_url=/lab/", \
     "--ServerApp.allow_origin=*", \
     "--notebook-dir=/app/notebooks"]
