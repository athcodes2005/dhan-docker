# --- Required: Dhan API Credentials ---
DHAN_CLIENT_ID=your_client_id
DHAN_API_KEY=your_api_key
DHAN_API_SECRET=your_api_secret
DHAN_PIN=your_6_digit_pin
DHAN_TOTP_SEED=your_totp_seed

# --- Required: Dashboard Auth ---
SECRET_KEY=generate_with_python_-c_"import secrets; print(secrets.token_hex(32))"
ADMIN_PASSWORD=your_admin_password
GUEST_PASSWORD=your_guest_password

# --- Optional: Domain & TLS ---
# DOMAIN=your-subdomain.duckdns.org
# DUCKDNS_TOKEN=your_duckdns_token

# --- Optional: Static IP for Dhan ---
# STATIC_IP=your_server_ip
